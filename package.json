{
  "name": "@loomal/sdk",
  "version": "0.6.2",
  "description": "Official Node.js SDK for the Loomal API — identity infrastructure for AI agents and Loomal Pay (x402 paywall)",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./paywall/express": {
      "import": {
        "types": "./dist/paywall/express.d.mts",
        "default": "./dist/paywall/express.mjs"
      },
      "require": {
        "types": "./dist/paywall/express.d.ts",
        "default": "./dist/paywall/express.js"
      }
    },
    "./paywall/hono": {
      "import": {
        "types": "./dist/paywall/hono.d.mts",
        "default": "./dist/paywall/hono.mjs"
      },
      "require": {
        "types": "./dist/paywall/hono.d.ts",
        "default": "./dist/paywall/hono.js"
      }
    },
    "./paywall/mcp": {
      "import": {
        "types": "./dist/paywall/mcp.d.mts",
        "default": "./dist/paywall/mcp.mjs"
      },
      "require": {
        "types": "./dist/paywall/mcp.d.ts",
        "default": "./dist/paywall/mcp.js"
      }
    },
    "./webhook": {
      "import": {
        "types": "./dist/webhook.d.mts",
        "default": "./dist/webhook.mjs"
      },
      "require": {
        "types": "./dist/webhook.d.ts",
        "default": "./dist/webhook.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "prepublishOnly": "npm run build && npm test"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "loomal",
    "ai",
    "agent",
    "email",
    "mcp",
    "did",
    "vault",
    "sdk",
    "x402",
    "paywall",
    "usdc",
    "payments"
  ],
  "license": "MIT",
  "author": "Loomal",
  "homepage": "https://loomal.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/loomal-ai/loomal-node.git"
  },
  "bugs": {
    "url": "https://github.com/loomal-ai/loomal-node/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "express": ">=4"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
